// Postgres (driver adapter in lib/db.ts). DATABASE_URL 换成 Neon 连接串后，
// 跑一次 `prisma migrate deploy` 即可部署到云端，业务代码不用改。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("student") // student | teacher
  createdAt    DateTime @default(now())

  sessions   Session[]
  challenges Challenge[]
  posts      Post[]
  likes      Like[]
  comments   Comment[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Challenge {
  id                 String   @id @default(cuid())
  teacherId          String
  teacher            User     @relation(fields: [teacherId], references: [id])
  status             String   @default("active") // active | paused | ended
  brandName          String
  brandBackground    String
  goal               String
  targetAudience     Json
  seasonalContext    String
  followerBase       Int
  totalRounds        Int
  startingTokens     Int
  difficulty         String
  availableActions   Json
  leaderboardEnabled Boolean
  joinCode           String   @unique
  createdAt          DateTime @default(now())

  groups Group[]
}

model Group {
  id           String    @id @default(cuid())
  challengeId  String
  challenge    Challenge @relation(fields: [challengeId], references: [id])
  groupName    String
  tokenBalance Int
  currentRound Int       @default(1)
  status       String    @default("in_progress") // in_progress | finished
  finalScore   Int?
  createdAt    DateTime  @default(now())

  rounds Round[]

  @@unique([challengeId, groupName])
}

model Round {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  round     Int
  post      Json
  actions   Json
  result    Json
  createdAt DateTime @default(now())

  plazaPost Post?

  @@unique([groupId, round])
}

model Post {
  id           String   @id @default(cuid())
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])
  text         String
  hashtags     String[]
  imageUrl     String?
  source       String // "round" | "free"
  roundId      String?  @unique
  round        Round?   @relation(fields: [roundId], references: [id])
  productId    String?
  product      Product? @relation(fields: [productId], references: [id])
  likeCount    Int      @default(0)
  commentCount Int      @default(0)
  createdAt    DateTime @default(now())

  likes    Like[]
  comments Comment[]

  @@index([createdAt])
}

model Product {
  id       String   @id @default(cuid())
  title    String
  category String
  price    Int
  tags     String[]
  imageUrl String?

  posts Post[]
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  text      String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}
