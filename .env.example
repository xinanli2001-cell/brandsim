# 本地: postgresql://postgres:postgres@localhost:5432/brandsim?sslmode=disable
# Neon: postgresql://<user>:<pw>@<host>.neon.tech/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# 可选：真实 LLM 打分（OpenAI 兼容接口，也可指向 DeepSeek 等兼容供应商）
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=              # 留空则用 OpenAI 官方地址；DeepSeek 填 https://api.deepseek.com，OPENAI_MODEL 对应改成 deepseek-chat
# 注意：DeepSeek 没有 embedding 接口，配置 DeepSeek 后语义检索仍会退化为关键词检索
